{
  "name": "bet-the-hackers",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "NEXT_TEST_WASM=1 NEXT_TEST_WASM_DIR=node_modules/@next/swc-wasm-nodejs node node_modules/next/dist/bin/next dev --webpack",
    "build": "NEXT_TEST_WASM=1 NEXT_TEST_WASM_DIR=node_modules/@next/swc-wasm-nodejs node node_modules/next/dist/bin/next build --webpack",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/next/dist/bin/next lint",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "prisma:generate": "bun --env-file=.env.local node_modules/prisma/build/index.js generate",
    "prisma:push": "bun --env-file=.env.local node_modules/prisma/build/index.js db push",
    "prisma:seed": "bun --env-file=.env.local prisma/seed.ts",
    "prisma:studio": "bun --env-file=.env.local node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "lucide-react": "^0.468.0",
    "mongodb": "^7.2.0",
    "next": "16.2.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "16.2.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.6",
    "prisma": "6.19.3",
    "typescript": "^5.7.2"
  }
}
