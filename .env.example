# Copy this file to .env.local and fill in real values.
# Do not commit .env.local.

# ─── MongoDB ──────────────────────────────────────────────────────────
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/bet-the-hack?retryWrites=true&w=majority"
# MONGODB_DB="bet-the-hack"                 # only set if URI doesn't include db in path
MONGODB_TEAMS_COLLECTION="teams"
MONGODB_SUBMISSIONS_COLLECTION="submissions"
MONGODB_JUDGES_COLLECTION="judges"
MONGODB_SCORES_COLLECTION="scores"
MONGODB_EVIDENCE_COLLECTION="evidence"
MONGODB_SWIPES_COLLECTION="swipes"

# ─── Agents ───────────────────────────────────────────────────────────
# Without any of these, the dashboard runs in STUB mode (heuristic
# scoring, mock LinkedIn/research data). Drop in real keys and the same
# code flips to live calls — no refactor needed.

# OpenAI — orchestration LLM that powers the scoring agents.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Image model for team cover art (DALL-E 3 standard 1024x1024 ≈ $0.04/image)
OPENAI_IMAGE_MODEL=dall-e-3

# Apify — LinkedIn enrichment for participants and judges.
# https://console.apify.com/account/integrations
# Actor slug: pick a public LinkedIn profile scraper.
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR=dev_fusion~linkedin-profile-scraper

# Nia — deep oracle research for marketability + judge background.
# https://docs.trynia.ai/
NIA_API_KEY=
# NIA_API_BASE=https://api.trynia.ai

# Hyperspell — memory/evidence layer. Without it, evidence falls back to
# a Mongo `evidence` collection (so the dashboard still works).
# https://hyperspell.com/  →  email hello@hyperspell.com
HYPERSPELL_API_KEY=
# HYPERSPELL_API_BASE=https://api.hyperspell.com
