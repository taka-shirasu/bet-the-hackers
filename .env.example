# Copy this file to .env.local and fill in your real MongoDB values.
# Do not commit .env.local.

MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/nozomio?retryWrites=true&w=majority"
MONGODB_DB="nozomio"
MONGODB_TEAMS_COLLECTION="teams"

# Optional, only needed if we store swipe sessions or winner selections.
MONGODB_SWIPES_COLLECTION="swipes"
